<?xml version="1.0" encoding="UTF-8"?>
<!--
  Plug-in descriptor for the Appian plug-in framework.

  Packaged at the JAR ROOT (this file lives at src/main/resources/appian-plugin.xml,
  which Maven copies straight to the root of target/classes and, from there, to the
  root of the built JAR) - Appian's documented plug-in project structure requires
  appian-plugin.xml at the JAR root, not under META-INF.
  Reference: https://docs.appian.com/suite/help/26.6/Custom_Smart_Service_Plug-ins.html

  Root element is <appian-plugin>, not <plugin> as the docs page above literally
  shows - confirmed against lowcodemindsglobal/appian-header-match-plugin, a real,
  successfully deployed sibling plug-in from this org, which uses <appian-plugin>.

  IMPORTANT: "key" below is a permanent identifier. Once this plug-in is deployed
  anywhere, never change it - Appian best practice is to deprecate old smart
  services (move them to the "Deprecated Services" palette category) rather than
  remove or rename them, so processes already using this node keep working.
  Renamed from com.lowcodeminds.plugins.excel-export-plugin-v2 to
  com.lowcodeminds.plugins.advance-excel-export as part of the "Advance Excel
  Export" rebrand - safe only because this plug-in had not yet been deployed
  anywhere. Do not repeat this rename after a real deployment.
-->
<appian-plugin name="Advance Excel Export"
               key="com.lowcodeminds.plugins.advance-excel-export">

  <plugin-info>
    <description>Runs SQL queries against a JNDI data source and exports the results to a
      multi-sheet, column-protected Excel (.xlsx) document.</description>
    <vendor name="LowCodeMinds" url="https://www.lowcodeminds.com"/>
    <version>1.0.0</version>
    <!--
      24.4 is the actual confirmed floor, not a guess: a real deployment
      attempt against a live Appian instance running 24.4.460.0 failed the
      version gate with min="25.1" set ("requires a minimum version of 25.1.0.
      The installed version of Appian is 24.4.460.0"), proving the earlier
      "Appian version greater than 25" assumption wrong before this plug-in
      ever got past that check to load a single class. 25.0.0-local (the
      appian-plugin-sdk coordinate this project compiles against, see
      pom.xml) remains just a placeholder version string with no real bearing
      on the minimum supported release - don't infer a floor from it again.
      Also documented in the README's compatibility section. Appian's
      AppMarket Submission Policies for Plug-Ins require clearly documented
      version compatibility - undocumented plug-ins are removed from the
      AppMarket.
    -->
    <application-version min="24.4"/>
  </plugin-info>

  <!-- Data Type -->
  <datatype key="SQLSheetData" name="Input Datatype for Advance Excel Export">
    <class>com.lowcodeminds.appian.plugins.excel.SQLSheetData</class>
  </datatype>

  <!--
    SmartServiceContext, ContentService, and javax.naming.Context are injected
    into AdvanceExcelExport's constructor automatically by the Appian plug-in
    framework, which recognizes constructor parameters typed as
    SmartServiceContext, public *Service interfaces, or as Context - no manual
    wiring belongs here.

    The smart-service "key" below is, like the plug-in key above, a permanent
    identifier once deployed - it was renamed here from excelExportSmartService
    to advanceExcelExport as part of the same rebrand, safe only because this
    plug-in had not yet been deployed anywhere. Do not repeat this rename after
    a real deployment.
  -->
  <smart-service name="Excel Export"
                 key="advanceExcelExport"
                 class="com.lowcodeminds.appian.plugins.excel.AdvanceExcelExport"/>

  <!--
    Versioning/deprecation convention for AFTER this plug-in has been deployed at
    least once (per Appian's documented guidance: "If you need to modify the
    inputs or outputs of a smart service, create a new smart service and
    deprecate the previous version" - existing process models keep resolving the
    old key/inputs, so nothing already built breaks):

    1. Do NOT edit this <smart-service> element's "key", or add/remove/retype any
       of AdvanceExcelExport's @Input/@Name inputs or outputs, once deployed.
    2. If the input/output contract must change, add a NEW <smart-service> entry
       here with a new key (advanceExcelExportV2, advanceExcelExportV3, ...) and
       a correspondingly renamed/new Java class - never repurpose this key.
    3. Move this entry's palette placement to Appian's "Deprecated Services"
       category (e.g. via @PaletteInfo on the now-superseded class) rather than
       removing it, so processes already using "Excel Export" keep working.
    4. Bump <version> above for every change, per Appian's plug-in versioning
       guidance, whether or not a new smart-service entry was added.
  -->

</appian-plugin>
