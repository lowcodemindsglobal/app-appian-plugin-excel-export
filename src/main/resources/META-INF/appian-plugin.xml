<?xml version="1.0" encoding="UTF-8"?>
<!--
  NOTE: This file's schema/namespace is NOT verified against your specific Appian
  version. Unlike the Java classes in this project (verified directly against
  lib/appian-plug-in-sdk.jar's bytecode), this descriptor format is defined by
  Appian's plugin packaging tooling/documentation, which is not embedded in the
  SDK jar and has changed across Appian releases.

  Before deploying: compare this against an existing internal plugin's
  appian-plugin.xml (if your team has one) or your Appian version's "Building
  Smart Service Plug-ins" developer documentation, and correct the namespace,
  element names, and bean-wiring convention as needed.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                            http://www.springframework.org/schema/beans/spring-beans.xsd">

  <!--
    "content-service" is the conventional bean id Appian exposes for
    com.appiancorp.suiteapi.content.ContentService in classic smart-service
    plugin wiring. Confirm this bean id against your Appian version if the
    plugin fails to deploy with a bean-not-found error.
  -->
  <bean id="excelExportSmartService"
        class="com.lowcodeminds.appian.plugins.excel.ExcelExportSmartService">
    <constructor-arg ref="content-service"/>
  </bean>

</beans>
